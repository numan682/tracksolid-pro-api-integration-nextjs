# ---- Tracksolid Pro Open API credentials ----
# The master/distributor account that owns the Open API app credential.
TRACKSOLID_ACCOUNT=your_account
# Account password. Plain text OR a 32-char MD5 hash (both are accepted).
TRACKSOLID_PASSWORD=your_password_or_md5
# Open API app key & secret (from your Tracksolid Open API console).
TRACKSOLID_APP_KEY=your_app_key
TRACKSOLID_APP_SECRET=your_app_secret
# API node base URL for your region (example below is the BGD node).
TRACKSOLID_API_URL=https://bgd.tracksolidpro.com/route/rest

# ---- App session ----
# Random 32+ char string used to encrypt session cookies (AES-256-GCM).
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_string
